PROJECT_NAME= # reNews - default
ENVIRONMENT= # development(default) or production

# Database Configuration
POSTGRES_USER= # ----- Required
POSTGRES_PASSWORD= # ----- Required
POSTGRES_DB= # ----- Required
POSTGRES_HOST= # 'db' - default
POSTGRES_PORT= # 5432 - default


# Admin sequrity
JWT_SECRET= # ----- Required, ensure 32-bit lenght
ALGORITHM= # HS256 - default
ACCESS_TOKEN_EXPIRE_MINUTES= # 60 minutes - default
ADMIN_USER= # ----- Required
ADMIN_PASS= # ----- Required

# AI config
GEMINI_API_KEY= # ----- Required
GEMINI_MODEL = gemini-3.1-flash-lite-preview # gemini-3.1-flash-lite-preview - default

# Worker config
USER_AGENT= # reNews-Reader/2.0 (+https://github.com/andriydread/reNews) - default
MAX_CONTENT_LENGTH=  # Limit text sent to AI to save tokens, 15000 - default
WORKER_INTERVAL_MINUTES=  # 30 minutes - default